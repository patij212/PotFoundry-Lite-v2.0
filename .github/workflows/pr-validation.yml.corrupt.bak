```github-actions-workflow
name: PR Validation

on:
  pull_request:
    types: [opened, synchronize, reopened]
  workflow_dispatch: {}
  push:
    branches:
      - fix/edgeflow-debug-quick

concurrency:
  # Use a ref-based group to avoid failures when the workflow is triggered
  # by non-pull_request events where github.event.pull_request.number is not set.
  name: PR Validation

  on:
    pull_request:
      types: [opened, synchronize, reopened]
    workflow_dispatch: {}

  concurrency:
    # Use a ref-based group to avoid failures when the workflow is triggered
    # by non-pull_request events where github.event.pull_request.number is not set.
    group: pr-validation-${{ github.ref }}
    cancel-in-progress: true
name: PR Validation

on:
  pull_request:
    types: [opened, synchronize, reopened]
  workflow_dispatch: {}
  push:
    branches:
      - fix/edgeflow-debug-quick

concurrency:
  # Use a ref-based group to avoid failures when the workflow is triggered
  # by non-pull_request events where github.event.pull_request.number is not set.
  group: pr-validation-${{ github.ref }}
  cancel-in-progress: true

jobs:
  validate-pr:
    name: PR Quality Check
    runs-on: ubuntu-latest
    timeout-minutes: 45

    steps:
      - uses: actions/checkout@v3
        with:
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt
          pip install -r requirements-dev.txt

      - name: Run linters and static checks
        run: |
          python -m pip install --upgrade pip
          pip install ruff mypy
          # Linting and quick fixes (fails on issues)
          ruff check .
          # Strict static typing check used by CI
          python -m mypy --check-untyped-defs .

      - name: Run tests and capture coverage
        run: |
          set -o pipefail
          pytest tests/ -v \
            --cov=potfoundry --cov=pfui \
            --cov-report=term-missing \
            --cov-report=xml:coverage.xml | tee pytest_output.txt

      - name: Report summary to PR
        run: |
          echo "## PR Validation Summary" >> $GITHUB_STEP_SUMMARY
          # Extract coverage percentage from pytest output
          COVERAGE=$(grep "TOTAL" pytest_output.txt | awk '{print $4}' || true)
          echo "**Overall Coverage:** ${COVERAGE:-unknown}" >> $GITHUB_STEP_SUMMARY
          # Number of collected tests (fast, run collect-only)
          TEST_COUNT=$(pytest tests/ --collect-only -q | tail -1 || true)
          echo "**Total Tests:** ${TEST_COUNT:-unknown}" >> $GITHUB_STEP_SUMMARY
          # Add link to raw pytest output as artifact (optional)
          echo "(Coverage and test details available in workflow artifacts)" >> $GITHUB_STEP_SUMMARY

      - name: Upload test logs & coverage
        uses: actions/upload-artifact@v3
        with:
          name: pr-validation-logs
          path: |
            pytest_output.txt
            coverage.xml

      - name: Publish coverage to Codecov (optional)
        if: ${{ secrets.CODECOV_TOKEN != '' }}
        run: |
          python -m pip install codecov
          codecov -f coverage.xml || true
      - name: Publish coverage to Codecov (skipped)
        if: ${{ secrets.CODECOV_TOKEN == '' }}
        run: |
          echo "CODECOV_TOKEN not provided; skipping Codecov upload"

    auto-fix:
      name: Auto-format suggestions (ruff --fix)
      runs-on: ubuntu-latest
      needs: validate-pr
      timeout-minutes: 15

      steps:
        - uses: actions/checkout@v3
          with:
            fetch-depth: 0

        - name: Set up Python
          uses: actions/setup-python@v4
          with:
            python-version: '3.11'

        - name: Install ruff
          run: |
            python -m pip install --upgrade pip
            pip install ruff

        - name: Run ruff check (blocking)
          run: |
            ruff check .

        - name: Run ruff --fix and produce patch
          run: |
            # Apply fixes locally; do NOT commit automatically. Produce a patch for reviewers.
            ruff --fix . || true
            git config user.email "actions@github.com"
            git config user.name "github-actions[bot]"
            git diff > ruff-fix.patch || true
            if [ -s ruff-fix.patch ]; then echo "Ruff generated fixes available."; else echo "No ruff fixes needed."; fi

        - name: Upload ruff patch
          uses: actions/upload-artifact@v3
          with:
            name: ruff-fix
            path: ruff-fix.patch

    security-scan:
      name: Security Scan
      runs-on: ubuntu-latest
      timeout-minutes: 20

      steps:
        - uses: actions/checkout@v3

        - name: Set up Python
          uses: actions/setup-python@v4
          with:
            python-version: '3.11'

        - name: Install security tools
          run: |
            python -m pip install --upgrade pip
            pip install safety bandit

        - name: Check dependencies for known vulnerabilities
          run: |
            pip install -r requirements.txt
            safety check --json || true
          continue-on-error: true

        - name: Run bandit security linter
          run: |
            bandit -r potfoundry/ pfui/ -f json || true
          continue-on-error: true

```
