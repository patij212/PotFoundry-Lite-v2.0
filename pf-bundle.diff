@@ -1,10 +1,40 @@
 # STYLE_SCHEMAS already defines per-style controls.
 # Add globally useful spin controls so users can access twist without editing YAML.
+SPIN_CONTROLS = {
+    "spin_turns": {
+        "label": "Twist (turns)",
+        "type": "float",
+        "min": -3.0,
+        "max": 3.0,
+        "step": 0.05,
+        "default": 0.0,
+        "help": "Total twists from base to rim. Positive = CCW when viewed from top.",
+    },
+    "spin_phase_deg": {
+        "label": "Twist phase (°)",
+        "type": "float",
+        "min": -360,
+        "max": 360,
+        "step": 1.0,
+        "default": 0.0,
+        "help": "Rotational offset applied at Z=0.",
+    },
+    "spin_curve_exp": {
+        "label": "Twist ease exponent",
+        "type": "float",
+        "min": 0.1,
+        "max": 4.0,
+        "step": 0.1,
+        "default": 1.0,
+        "help": "1.0 = linear. >1 eases in, <1 eases out.",
+    },
+}
+
+# Merge spin controls into every style schema without overwriting existing keys.
+for _style_name, _schema in list(STYLE_SCHEMAS.items()):
+    for _k, _v in SPIN_CONTROLS.items():
+        if _k not in _schema:
+            _schema[_k] = _v