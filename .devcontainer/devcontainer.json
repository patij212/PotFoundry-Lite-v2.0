{
  "name": "PotFoundry Codespace",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "cd potfoundry-web && npm install",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "potfoundry-web/README.md"
      ]
    },
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Dev Server",
      "onAutoForward": "openPreview"
    }
  },
  "remoteUser": "node"
}
