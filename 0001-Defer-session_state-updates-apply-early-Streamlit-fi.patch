++++ b/pfui/state.py
+@@ -1,20 +1,54 @@
+ # pfui/state.py
+ from __future__ import annotations
+ import streamlit as st
+ 
+-from .schemas import STYLE_SCHEMAS   # << changed
++from .schemas import STYLE_SCHEMAS   # << ensure this import works
+ 
+ def widget_key(style: str, field: str) -> str:
+     return f"opt__{style}_{field}"
+ 
+-def reset_style_defaults(style: str) -> None:
+-    schema = STYLE_SCHEMAS.get(style, {})
+-    for key, meta in schema.items():
+-        st.session_state[widget_key(style, key)] = meta.get("default")
+-    st.session_state[widget_key(style, "flare_center")] = 0.5
+-    st.session_state[widget_key(style, "flare_sharp")]  = 6.0
+-    st.session_state[widget_key(style, "bell_amp")]     = 0.0
+-...
+-    st.session_state[widget_key(style, "bell_width")]   = 0.22
+-    st.session_state[widget_key(style, "spin_turns")]     = 0.0
+-    st.session_state[widget_key(style, "spin_phase_deg")] = 0.0
+-    st.session_state[widget_key(style, "spin_curve_exp")] = 1.0
++_PENDING_KEY = "__pending_updates__"
++
++def queue_update(updates: dict) -> None:
++    """Queue session_state updates to be applied on the next run, before widgets render."""
++    if _PENDING_KEY not in st.session_state:
++        st.session_state[_PENDING_KEY] = {}
++    st.session_state[_PENDING_KEY].update(updates)
 +
-+def dump_recipe_yaml(name: str, style_name: str, H: float, top_od: float, bottom_od: float,
-+                     t_wall: float, t_bottom: float, drain_diam: float, expn: float,
-+                     opts: Dict[str, Any]) -> str:
-+    """
-+    Return a YAML string containing a single-recipe config.
-+    IMPORTANT: The loader expects 'drain' to be a *diameter* (it halves it),
-+    and 'version' must be at the top level.
-+    """
-+    cfg: Dict[str, Any] = {
-+        "version": 2,
-+        "recipes": [{
-+            "name": name,
-+            "style": style_name,
-+            "size": {
-+                "height": H,
-+                "top_od": top_od,
-+                "bottom_od": bottom_od,
-+                "wall": t_wall,
-+                "bottom": t_bottom,
-+                "drain": drain_diam,   # diameter, not radius
-+                "flare_exp": expn,
-+            },
-+            "opts": opts or {},
-+        }],
-+    }
-+    return _yaml.safe_dump(cfg, sort_keys=False)
