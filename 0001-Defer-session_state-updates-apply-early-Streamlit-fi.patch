-diff --git a/potfoundry/yaml_api.py b/potfoundry/yaml_api.py
++def apply_pending_updates() -> None:
++    """Apply any queued updates. Call this *before* creating widgets."""
++    updates = st.session_state.pop(_PENDING_KEY, None)
++    if updates:
++        st.session_state.update(updates)
++
++def reset_style_defaults(style: str) -> None:
++    """Queue style-specific defaults; caller should st.rerun() after this."""
++    schema = STYLE_SCHEMAS.get(style, {})
++    updates = {widget_key(style, key): (meta.get("default") if isinstance(meta, dict) else None)
++               for key, meta in schema.items()}
++    # hard defaults for shared options
++    updates.update({
++        widget_key(style, "flare_center"): 0.5,
++        widget_key(style, "flare_sharp"):  6.0,
++        widget_key(style, "bell_amp"):     0.0,
++        widget_key(style, "bell_width"):   0.22,
++        widget_key(style, "spin_turns"):     0.0,
++        widget_key(style, "spin_phase_deg"): 0.0,
++        widget_key(style, "spin_curve_exp"): 1.0,
++    })
++    queue_update(updates)
+ 
+ def reset_all_defaults(style: str) -> None:
+-    st.session_state["H"]         = 120.0
+-    st.session_state["top_od"]    = 140.0
+-    st.session_state["bottom_od"] = 90.0
+-    st.session_state["t_wall"]    = 3.0
+-    st.session_state["t_bottom"]  = 3.0
+-    st.session_state["r_drain"]   = 10.0
+-    st.session_state["expn"]      = 1.1
+-    reset_style_defaults(style)
++    """Queue global + style defaults; caller should st.rerun() after this."""
++    queue_update({
++        "H":         120.0,
++        "top_od":    140.0,
++        "bottom_od": 90.0,
++        "t_wall":    3.0,
++        "t_bottom":  3.0,
++        "r_drain":   10.0,
++        "expn":      1.1,
++    })
++    reset_style_defaults(style)
