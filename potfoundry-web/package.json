{
    "name": "potfoundry-web",
    "version": "3.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:mobile": "cross-env VITE_MOBILE=1 vite",
        "dev:wrangler": "wrangler pages dev -- npm run dev",
        "build": "vite build",
        "preview": "vite preview",
        "deploy": "npm run build && wrangler pages deploy dist",
        "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
        "lint:wgsl": "node scripts/lint-wgsl-regions.mjs",
        "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
        "typecheck:full": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed"
    },
    "dependencies": {
        "@fontsource-variable/fraunces": "^5.2.9",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource/ibm-plex-mono": "^5.2.7",
        "@kninnug/constrainautor": "^4.0.1",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-focus-scope": "^1.1.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@supabase/supabase-js": "^2.45.0",
        "@types/react-window": "^1.8.8",
        "@types/three": "^0.182.0",
        "cdt2d": "^1.0.0",
        "clsx": "^2.1.1",
        "delaunator": "^5.0.1",
        "jszip": "^3.10.1",
        "lucide-react": "^0.555.0",
        "meshoptimizer": "^1.0.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-window": "^1.8.10",
        "stripe": "^14.0.0",
        "three": "^0.182.0",
        "zustand": "^5.0.9"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260101.0",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.57.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@types/react": "^18.3.1",
        "@types/react-dom": "^18.3.1",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitejs/plugin-basic-ssl": "^1.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@vitest/coverage-v8": "^4.0.17",
        "@webgpu/types": "^0.1.1",
        "cross-env": "^10.1.0",
        "eslint": "^9.10.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react": "^7.34.3",
        "eslint-plugin-react-hooks": "^5.2.0",
        "globals": "^15.15.0",
        "jsdom": "^27.4.0",
        "prettier": "^3.3.3",
        "typescript": "^5.5.4",
        "vite": "^5.4.0",
        "vitest": "^4.0.17"
    }
}
